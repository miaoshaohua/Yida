# ==========================================
# Yida AI虚拟试衣间 - 生产环境配置
# ==========================================
# 说明：
# 1. 复制此文件为 .env.prod 并填入真实配置
# 2. 如果使用Git部署，此文件不会被提交到仓库（已添加到.gitignore）
# 3. 生产环境请保管好此文件，不要泄露敏感信息
# ==========================================

# ==========================================
# 数据库配置
# ==========================================
# PostgreSQL 数据库密码
POSTGRES_PASSWORD=your-secure-database-password

# ==========================================
# JWT配置
# ==========================================
# 使用 openssl rand -base64 32 生成强密钥
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==========================================
# Cloudflare R2配置（图片存储）
# ==========================================
# 存储模式: r2(Cloudflare R2) 或 local(本地存储)
STORAGE_MODE=r2

# Cloudflare R2 配置（必填）
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=yida-images

# ==========================================
# FASHN VTON API配置
# ==========================================
FASHN_API_KEY=your-fashn-api-key
FASHN_API_URL=https://miaoshaohua--fashn-vton-api-fastapi-app.modal.run

# ==========================================
# 短信服务配置（阿里云/腾讯云）
# ==========================================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your-sms-access-key-id
SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
SMS_SIGN_NAME=AI试衣间
SMS_TEMPLATE_CODE=SMS_123456789

# ==========================================
# 管理员配置
# ==========================================
ADMIN_EMAIL=admin@yida.com
ADMIN_PASSWORD=your-secure-admin-password

# ==========================================
# 前端配置
# ==========================================
# 后端API地址（使用云服务器公网IP或域名）
# 如果使用域名，替换为: http://your-domain.com
VITE_API_BASE_URL=http://42.194.162.239:3000
