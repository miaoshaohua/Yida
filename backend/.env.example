# ===========================================
# Yida Backend Environment Configuration
# ===========================================
# 复制此文件为 .env 并填入实际配置值
# cp .env.example .env
# ===========================================

# 数据库连接 (PostgreSQL)
# 本地开发: postgresql://postgres:password@localhost:5432/yida
# 生产环境 (Railway): 由平台自动注入
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yida?schema=public"

# JWT 配置
# JWT_SECRET 建议使用 openssl rand -base64 32 生成
JWT_SECRET="your-jwt-secret-change-this"
JWT_EXPIRES_IN="2h"

# FASHN 虚拟试衣 API
FASHN_API_URL="https://miaoshaohua--fashn-vton-api-fastapi-app.modal.run"

# Redis 配置 (用于 Bull 任务队列)
# 本地开发: redis://localhost:6379
# 生产环境 (Upstash): redis://default:xxx@yyy.upstash.io:6379
REDIS_URL="redis://localhost:6379"

# 文件存储 (Cloudflare R2 / AWS S3 兼容)
# 本地开发时可不填，使用文件系统存储
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="yida-images"
R2_ACCOUNT_ID=""
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# 短信服务 (预留，暂不启用)
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME="易搭"
SMS_TEMPLATE_CODE="SMS_123456789"

# 应用配置
PORT=3000
NODE_ENV="development"

# CORS 配置
# 生产环境必填：前端域名
FRONTEND_URL="https://yida.com"
ADMIN_URL="https://admin.yida.com"
